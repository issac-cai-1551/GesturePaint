# Project Specific
# 先忽略 models 目录下所有内容
models/*
# 但放行 lora 子目录（关键规则）
!models/lora/
# 放行 lora 目录下的所有文件（包括子目录）
!models/lora/**/*

# 忽略除 lora 外的模型文件后缀（避免其他模型被误传）
*.pth
*.ckpt
# 仅排除非 lora 目录下的 safetensors/bin/task（放行 lora 下的）
!models/lora/**/*.safetensors
!models/lora/**/*.bin
!models/lora/**/*.task
*.safetensors
*.bin
*.task

# 生成的艺术作品
assets/auto_doodle_art/

# 日志文件
logs/
*.log

# 配置文件（如果有敏感信息）
config.ini
.env
*.env
secrets.yaml

# 数据库文件（如果有）
*.db
*.sqlite3

# 大文件（排除 lora 下的压缩包，避免误忽略）
!models/lora/**/*.zip
!models/lora/**/*.tar.gz
!models/lora/**/*.7z
*.zip
*.tar.gz
*.7z

# 临时文件
temp/
tmp/